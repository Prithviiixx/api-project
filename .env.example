# ─── AWS Credentials (local dev only — EC2 uses IAM role, no keys needed) ────
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=eu-north-1

# ─── SQS Queue URL (set by provision.py output) ───────────────────────────────
SQS_QUEUE_URL=https://sqs.eu-north-1.amazonaws.com/262252232019/invoice-processing-queue
